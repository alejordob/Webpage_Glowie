rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public catalog — anyone can read, only Glowie team can write
    match /artifacts/{appId}/public/data/{document=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in [
            'alejandroob001@gmail.com',
            'nataliahv1998@gmail.com',
            'candles.glowie@gmail.com'
          ];
    }

    // Per-user data (carts, wishlists, etc.) — each user owns their own
    match /artifacts/{appId}/users/{userId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Root-level products collection (legacy import path)
    match /products/{document=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in [
            'alejandroob001@gmail.com',
            'nataliahv1998@gmail.com',
            'candles.glowie@gmail.com'
          ];
    }

  }
}
