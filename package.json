{
  "name": "glowie-webpage",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./public/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./public/tailwind.css --watch",
    "generate-sitemap": "node script/generate-sitemap.js",
    "generate-prerender": "node script/generate-prerender.js",
    "deploy": "npm run generate-sitemap && npm run generate-prerender && npm run build:css && firebase deploy"
  },
  "devDependencies": {
    "puppeteer": "^24.40.0",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0"
  }
}
